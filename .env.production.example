APP_NAME=GoravelMine
APP_ENV=production
APP_KEY=base64:replace-with-generated-app-key
APP_DEBUG=false
APP_URL=https://admin.example.com
APP_HOST=0.0.0.0
APP_PORT=3000
APP_VERSION=0.1.0

JWT_SECRET=replace-with-strong-random-secret
JWT_TTL=120
JWT_REFRESH_TTL=20160

CORS_ALLOWED_ORIGINS=https://admin.example.com
CORS_SUPPORTS_CREDENTIALS=true

CACHE_STORE=redis
QUEUE_CONNECTION=redis
QUEUE_WORKER_ENABLED=false
QUEUE_CONCURRENT=2
QUEUE_APP_AUTO_RUN=false
QUEUE_SCHEDULER_ENABLED=false
QUEUE_SERVICE_WORKER_ENABLED=true
QUEUE_SERVICE_CONCURRENT=4
QUEUE_OUTBOX_ENABLED=true
QUEUE_OUTBOX_INTERVAL_SECONDS=5
QUEUE_OUTBOX_BATCH=20
QUEUE_OUTBOX_OWNER=queue-outbox-runner

DB_CONNECTION=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=goravel-mine
DB_USERNAME=goravel
DB_PASSWORD=replace-with-strong-db-password
DB_SCHEMA=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DB=0

LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_FORMATTER=json
LOG_PRINT=true
OBS_METRICS_ENABLED=true
OBS_METRICS_PATH=/metrics
OBS_METRICS_TOKEN=replace-with-metrics-token
OBS_REQUEST_ID_HEADER=X-Request-Id
OBS_TRACE_ID_HEADER=X-Trace-Id
OBS_SLOW_REQUEST_THRESHOLD_MS=1000
OBS_SLOW_REQUEST_MAX_ENTRIES=100
OBS_SLOW_SQL_MAX_ENTRIES=100
OBS_AUDIT_ENABLED=true

SECURITY_ENTERPRISE=true
SECURITY_MFA_TOTP_ISSUER=GoravelMine
SECURITY_MFA_CHALLENGE_MINUTES=5
SECURITY_MFA_REMEMBER_MINUTES=720
SECURITY_MFA_RECOVERY_CODES=8
SECURITY_ACCOUNT_LOCKOUT_ENABLED=true
SECURITY_ACCOUNT_LOCKOUT_MAX_FAILURES=5
SECURITY_ACCOUNT_LOCKOUT_WINDOW_MINUTES=15
SECURITY_ACCOUNT_LOCKOUT_LOCK_MINUTES=15
SECURITY_LOGIN_RISK_ENABLED=true
SECURITY_LOGIN_RISK_IP_WINDOW_MINUTES=15
SECURITY_LOGIN_RISK_IP_MAX_FAILURES=30
SECURITY_LOGIN_RISK_USER_AGENT_ENABLED=true
SECURITY_CSRF_TRUSTED_ORIGINS=https://admin.example.com
SECURITY_CSRF_SAME_SITE=lax
SECURITY_CSRF_COOKIE_SECURE=true
SECURITY_KEY_ROTATION_DAYS=90
SECURITY_AUDIT_RETENTION_DAYS=180
