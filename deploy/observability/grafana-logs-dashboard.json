        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=\"goravel-mine\"} | json trace_id=\"extra.trace_id\" | trace_id=~\"$trace_id\" |= \"$contains\"",
          "refId": "A"
        }
      ],
      "title": "Logs by trace_id",
      "type": "logs"
    }
  ],
