APP_NAME=Goravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_FORMATTER=json

OBS_METRICS_ENABLED=false
OBS_METRICS_PATH=/metrics
OBS_METRICS_TOKEN=
OBS_REQUEST_ID_HEADER=X-Request-Id
OBS_TRACE_ID_HEADER=X-Trace-Id
OBS_SLOW_REQUEST_THRESHOLD_MS=1000
OBS_SLOW_REQUEST_MAX_ENTRIES=100
OBS_SLOW_SQL_MAX_ENTRIES=100
OBS_AUDIT_ENABLED=true

OTEL_PROPAGATORS=tracecontext,baggage
OTEL_TRACES_EXPORTER=
OTEL_METRICS_EXPORTER=
OTEL_LOGS_EXPORTER=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318

SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_URL=http://localhost
APP_HOST=127.0.0.1
APP_PORT=3000

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

CORS_PATHS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
CORS_ALLOWED_ORIGINS=http://localhost:2888,http://127.0.0.1:2888
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,X-Request-Id,X-Trace-Id,X-CSRF-Token,X-Tenant,X-Tenant-Code
CORS_EXPOSED_HEADERS=Content-Disposition,X-Request-Id,X-Trace-Id
CORS_MAX_AGE=600
CORS_SUPPORTS_CREDENTIALS=false

SECURITY_ENTERPRISE=false
SECURITY_MFA_TOTP_ENABLED=false
SECURITY_MFA_TOTP_ISSUER=Goravel
SECURITY_MFA_CHALLENGE_MINUTES=5
SECURITY_MFA_REMEMBER_MINUTES=720
SECURITY_MFA_RECOVERY_CODES=8
SECURITY_PASSWORD_MIN_LENGTH=6
SECURITY_PASSWORD_REQUIRE_UPPERCASE=false
SECURITY_PASSWORD_REQUIRE_LOWERCASE=false
SECURITY_PASSWORD_REQUIRE_NUMBER=false
SECURITY_PASSWORD_REQUIRE_SYMBOL=false
SECURITY_PASSWORD_HISTORY_LIMIT=0
SECURITY_PASSWORD_MAX_AGE_DAYS=0
SECURITY_PASSWORD_CHANGE_CHALLENGE_MINUTES=5
SECURITY_ACCOUNT_LOCKOUT_ENABLED=true
SECURITY_ACCOUNT_LOCKOUT_MAX_FAILURES=5
SECURITY_ACCOUNT_LOCKOUT_WINDOW_MINUTES=15
SECURITY_ACCOUNT_LOCKOUT_LOCK_MINUTES=15
SECURITY_LOGIN_RISK_ENABLED=true
SECURITY_LOGIN_RISK_IP_WINDOW_MINUTES=15
SECURITY_LOGIN_RISK_IP_MAX_FAILURES=30
SECURITY_LOGIN_RISK_USER_AGENT_ENABLED=true
SECURITY_CSRF_ENABLED=false
SECURITY_CSRF_TRUSTED_ORIGINS=
SECURITY_CSRF_SAME_SITE=lax
SECURITY_CSRF_COOKIE_SECURE=
SECURITY_SENSITIVE_FIELDS=password,old_password,new_password,new_password_confirmation,access_token,refresh_token,password_change_token,token,id_token,jwt_secret,client_secret,secret_key,db_password
SECURITY_KEY_ROTATION_DAYS=90
APP_KEY_ROTATED_AT=
JWT_SECRET_ROTATED_AT=
SSO_SAML_PRIVATE_KEY_ROTATED_AT=
STORAGE_S3_SECRET_KEY_ROTATED_AT=
SECURITY_AUDIT_RETENTION_DAYS=180
SECURITY_IMMUTABLE_EVIDENCE_MAX_BYTES=67108864

DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=goravel-mine
DB_USERNAME=root
DB_PASSWORD=root
DB_SCHEMA=public
DB_POOL_MAX_OPEN=20
DB_POOL_MAX_IDLE=10
APP_POD_COUNT=3

TENANT_DEFAULT=default
TENANT_PLATFORM_CONNECTION=postgres
TENANT_DATABASE_CONNECTION_BUDGET=500
TENANT_DATABASE_CONNECTION_BUDGET_OVERRIDE=false

CACHE_STORE=redis
QUEUE_CONNECTION=sync
QUEUE_WORKER_ENABLED=true
QUEUE_CONCURRENT=1
QUEUE_OUTBOX_ENABLED=true
QUEUE_OUTBOX_INTERVAL_SECONDS=5
QUEUE_OUTBOX_BATCH=20
QUEUE_OUTBOX_OWNER=queue-outbox-runner
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

GRPC_HOST=
GRPC_PORT=

MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
